<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>MODA ESSENTIAL | Playeras estilo H&M</title>
    <meta name="description"
        content="Colección de playeras básicas y de moda, calidad premium, diseños minimalistas inspirados en H&M.">

    <!-- Fuentes Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap"
        rel="stylesheet">

    <!-- Font Awesome 6 (íconos) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <!-- CSS externo -->
    <link rel="stylesheet" href="nova.css">
</head>

<body>

    <!-- BANNER SUPERIOR (estilo H&M) -->
    <div class="top-banner">
        <span>ENVÍO GRATIS EN PEDIDOS +$999 MXN</span>
        <span>DEVOLUCIONES FÁCILES | 30 DÍAS</span>
    </div>

    <!-- HEADER / NAVEGACIÓN -->
    <header class="main-header">
        <div class="logo">
            <h1>NOVA.<span>MODA</span></h1>
        </div>

        <nav class="nav-links">
            <ul>
                <li><a href="#" class="active">NUEVO</a></li>
                <li><a href="#">PLAYERAS</a></li>
                <li><a href="#">BÁSICOS</a></li>
                <li><a href="#">OFERTAS</a></li>
                <li><a href="#">INSPIRACIÓN</a></li>
            </ul>
        </nav>

        <div class="header-icons">
            <i class="fas fa-search" id="search-trigger" title="Buscar productos"></i>
            <i class="far fa-user" id="user-trigger" title="Mi Cuenta"></i>
            <i class="far fa-heart" id="wishlist-trigger" title="Favoritos"></i>
            <i class="fas fa-shopping-bag" id="cart-icon" title="Mi Bolsa"></i>
            <span id="cart-count" class="cart-count">0</span>
        </div>

        <!-- Botón menú hamburguesa (responsive) -->
        <div class="menu-toggle">
            <i class="fas fa-bars"></i>
        </div>
    </header>

    <!-- SECCIÓN HERO (imagen de fondo estilo campaña) -->
    <section class="hero">
        <div class="hero-content">
            <p class="hero-sub">EDICIÓN VERANO 2026</p>
            <h2>LA PERFECCIÓN DEL ALGODÓN</h2>
            <p>Playeras 100% orgánicas, cortes relajados y sostenibilidad. <br> Desde $450 MXN.</p>
            <a href="#" class="btn-hero">COMPRAR AHORA →</a>
        </div>
    </section>

    <!-- FILTROS Y ORDENACIÓN -->
    <div class="filters-container">
        <div class="filter-group">
            <button class="filter-btn active-filter" data-category="todos">TODOS</button>
            <button class="filter-btn" data-category="basico">BÁSICOS</button>
            <button class="filter-btn" data-category="estampado">ESTAMPADOS</button>
            <button class="filter-btn" data-category="oversize">OVERSIZE</button>
        </div>
        <div class="sort-group">
            <span>ORDENAR POR</span>
            <select id="sort-select">
                <option value="default">Destacados</option>
                <option value="price-asc">Precio: menor a mayor</option>
                <option value="price-desc">Precio: mayor a menor</option>
            </select>
        </div>
    </div>

    <!-- GALERÍA DE PRODUCTOS (PLAYERAS) -->
    <section class="products-section">
        <div class="products-grid" id="products-grid">
            <!-- Los productos se cargarán dinámicamente con JavaScript -->
        </div>
    </section>

    <!-- MODAL / CARRITO LATERAL (estilo H&M) -->
    <div class="cart-overlay" id="cart-overlay">
        <div class="cart-sidebar">
            <div class="cart-header">
                <h3>MI BOLSA <span id="cart-total-items">0</span></h3>
                <i class="fas fa-times close-cart" id="close-cart"></i>
            </div>
            <div class="cart-items" id="cart-items-list">
                <div class="empty-cart-msg">Tu bolsa está vacía</div>
            </div>
            <div class="cart-footer">
                <div class="cart-total">
                    <span>Subtotal</span>
                    <span id="cart-subtotal">$0 MXN</span>
                </div>
                <button class="checkout-btn">PROCEDER AL PAGO</button>
                <p class="cart-note">Envío calculado al finalizar</p>
            </div>
        </div>
    </div>

    <!-- NEWSLETTER -->
    <section class="newsletter">
        <div class="newsletter-content">
            <h4>¿MÁS ESTILO?</h4>
            <p>Suscríbete y recibe un 10% OFF en tu primera compra + novedades semanales.</p>
            <form id="newsletter-form">
                <input type="email" placeholder="Tu correo electrónico" required>
                <button type="submit">SUSCRÍBETE →</button>
            </form>
            <small>Promociones exclusivas, sin spam.</small>
        </div>
    </section>

    <!-- FOOTER -->
    <footer>
        <div class="footer-grid">
            <div class="footer-col">
                <h4>ATENCIÓN AL CLIENTE</h4>
                <ul>
                    <li><a href="#">Preguntas frecuentes</a></li>
                    <li><a href="#">Devoluciones</a></li>
                    <li><a href="#">Envíos</a></li>
                    <li><a href="#">Tallas</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>DESCUBRE</h4>
                <ul>
                    <li><a href="#">Novedades</a></li>
                    <li><a href="#">Sostenibilidad</a></li>
                    <li><a href="#">Acerca de ESSENTIAL</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>SÍGUENOS</h4>
                <div class="social-icons">
                    <i class="fab fa-instagram"></i>
                    <i class="fab fa-facebook-f"></i>
                    <i class="fab fa-twitter"></i>
                    <i class="fab fa-pinterest"></i>
                </div>
            </div>
        </div>
        <div class="copyright">
            <p>© 2026 NOVA MODA — Inspirado en la moda escandinava. Hecho con ❤️ para los amantes de las playeras.
            </p>
        </div>
    </footer>

    <!-- BUSCADOR DESPLEGABLE -->
    <div class="search-overlay" id="search-overlay">
        <div class="search-box">
            <i class="fas fa-search"></i>
            <input type="text" id="search-input" placeholder="Buscar playeras (ej. básica, oversize, blanca)...">
            <i class="fas fa-times close-search" id="close-search"></i>
        </div>
    </div>

    <!-- MODAL GENERAL (Checkout / Login / Wishlist) -->
    <div class="modal-overlay" id="custom-modal">
        <div class="modal-content">
            <i class="fas fa-times close-modal" id="close-modal"></i>
            <div id="modal-body"></div>
        </div>
    </div>

    <!-- CONTENEDOR PARA NOTIFICACIONES TOAST -->
    <div class="toast-container" id="toast-container"></div>

    <!-- JavaScript externo -->
    <script src="nova.js"></script>
</body>

</html>
